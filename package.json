{
  "name": "@dcl/report-site",
  "version": "0.0.1",
  "description": "UI for Decentraland players to report other players",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "init": "./start.sh && npm run husky-setup",
    "dev": "vite",
    "start": "vite",
    "prebuild": "node scripts/prebuild.cjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:coverage": "npm run test -- --coverage",
    "prepare": "husky",
    "precommit": "lint-staged --config .husky/pre-commit.js",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,json,md,mdx,css}'",
    "lint": "eslint --config eslint.config.cjs ./src",
    "lint:fix": "npm run lint -- --fix",
    "lint:pkg": "npmPkgJsonLint ."
  },
  "dependencies": {
    "@dcl/core-web3": "^0.4.0",
    "@dcl/hooks": "^1.2.0",
    "@magic-ext/oauth2": "15.0.0",
    "@dcl/schemas": "^22.4.0",
    "@dcl/single-sign-on-client": "0.1.0",
    "@dcl/ui-env": "^2.0.0",
    "@reduxjs/toolkit": "2.5.0",
    "@tanstack/react-query": "5.90.12",
    "decentraland-ui2": "1.3.4",
    "magic-sdk": "33.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-redux": "9.2.0",
    "react-router-dom": "7.13.0",
    "redux": "5.0.1",
    "viem": "2.41.2",
    "wagmi": "2.19.5"
  },
  "devDependencies": {
    "@dcl/eslint-config": "^3.1.0",
    "@types/jest": "29.5.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.52.0",
    "@typescript-eslint/parser": "8.52.0",
    "@vitejs/plugin-react": "4.3.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-autofix": "2.2.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "9.0.11",
    "jest": "29.7.0",
    "lint-staged": "15.2.7",
    "npm-package-json-lint": "8.0.0",
    "prettier": "3.8.1",
    "ts-jest": "29.1.5",
    "ts-node": "10.9.2",
    "typescript": "5.5.3",
    "vite": "5.3.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decentraland/report.git"
  },
  "keywords": [
    "decentraland",
    "dapps",
    "report"
  ],
  "author": "Decentraland",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/decentraland/report/issues"
  },
  "homepage": "",
  "engines": {
    "node": ">=20",
    "npm": ">=8"
  },
  "overrides": {
    "@types/node": "20.8.3",
    "@walletconnect/logger": {
      "pino": "10.0.0"
    },
    "react-redux": "$react-redux",
    "redux": "$redux"
  }
}
